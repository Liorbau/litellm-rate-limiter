# Copy to .env and fill in. LiteLLM and the Python clients read these at runtime.

# Proxy admin key (must start with sk-). Used by rate_limiter.py and test_config.py.
LITELLM_MASTER_KEY=sk-your-master-key

# OpenAI API keys for the two logical deployments (can be the same key for local demos).
TEAM_A_API_KEY=sk-your-openai-key
TEAM_B_API_KEY=sk-your-openai-key
